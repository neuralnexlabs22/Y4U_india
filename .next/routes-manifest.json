        "nxtPcategory": "nxtPcategory"
      },
      "namedRegex": "^/(?<nxtPcategory>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[category]/[brand]",
      "regex": "^/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategory": "nxtPcategory",
        "nxtPbrand": "nxtPbrand"
      },
      "namedRegex": "^/(?<nxtPcategory>[^/]+?)/(?<nxtPbrand>[^/]+?)(?:/)?$"
    }
  ],
